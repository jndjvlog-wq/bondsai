# ============================================
# BONDSAI.US — Environment Variables Template
# Copy this file to .env.local and fill in keys
# NEVER commit .env.local to git
# ============================================

# --- ATTOM Data API (Property Records) ---
# Sign up: https://api.developer.attomdata.com
ATTOM_API_KEY=your_attom_api_key_here

# --- RentCast API (Property + Rent Estimates) ---
# Sign up: https://app.rentcast.io/app
RENTCAST_API_KEY=your_rentcast_api_key_here

# --- App Settings ---
NEXT_PUBLIC_APP_NAME=BondSAI
NEXT_PUBLIC_APP_URL=https://bondsai.us

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# --- Logging ---
LOG_LEVEL=info
